<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Blue Rose</title>
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>

<canvas id="bg"></canvas>

<nav class="navbar">
  <h2 class="logo">💎 Blue Rose</h2>
  <ul>
    <li><a href="#nosotros">Nosotros</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#contacto">Solicitar</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-content">
    <h1>Desarrollamos software que impulsa negocios</h1>
    <p>Equipo de desarrolladores fullstack especializados en productos digitales escalables</p>

    <!-- BOTÓN -->
    <a href="#contacto" class="btn rose-btn">
      Solicitar proyecto

      <div class="rose-container">
        <svg viewBox="0 0 200 200" class="rose-svg">

          <path class="rose-path layer1"
            d="M60 100 C80 80,100 80,100 100 C100 120,80 120,60 100 Z"/>

          <path class="rose-path layer2"
            d="M60 100 C90 60,140 80,120 110 C140 140,90 160,60 100 Z"/>

          <path class="rose-path layer3"
            d="M60 100 C100 40,170 80,140 120 C170 160,100 180,60 100 Z"/>

          <path class="rose-path layer4"
            d="M60 100 C110 30,190 90,150 130 C190 170,110 200,60 100 Z"/>

        </svg>
      </div>
    </a>

  </div>
</section>

<section id="nosotros" class="section">
  <h2>Nosotros</h2>
  <p>
    En Blue Rose somos un equipo de desarrolladores enfocados en construir
    soluciones digitales modernas, escalables y eficientes.
  </p>
</section>

<section id="servicios" class="section dark">
  <h2>Servicios</h2>
  <div class="cards">
    <div class="card">Aplicaciones Web</div>
    <div class="card">Backend & APIs</div>
    <div class="card">Automatización</div>
  </div>
</section>

<section id="portfolio" class="section">
  <h2>Portfolio</h2>
  <div class="cards">
    <div class="card">Sistema de gestión</div>
    <div class="card">E-commerce</div>
    <div class="card">App SaaS</div>
  </div>
</section>

<section id="contacto" class="section dark">
  <h2>Trabajemos juntos</h2>
  <form class="form">
    <input type="text" placeholder="Nombre" required>
    <input type="email" placeholder="Email" required>
    <textarea placeholder="Contanos tu idea"></textarea>
    <button type="submit">Enviar solicitud</button>
  </form>
</section>

<script src="/js/home.js"></script>
</body>
</html>