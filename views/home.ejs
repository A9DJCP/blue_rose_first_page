<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Blue Rose</title>
  <link rel="stylesheet" href="/css/home.css">
</head>
<body>

<canvas id="bg"></canvas>

<nav class="navbar">
  <h2 class="logo">💎 Blue Rose</h2>
  <ul>
    <li><a href="#nosotros">Nosotros</a></li>
    <li><a href="#servicios">Servicios</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#contacto">Solicitar</a></li>
  </ul>
</nav>

<section class="hero">
  <div class="hero-content">
    <h1>Desarrollamos software que impulsa negocios</h1>
    <p>Equipo de desarrolladores fullstack especializados en productos digitales escalables</p>
    <a href="#contacto" class="btn">Solicitar proyecto</a>
  </div>
</section>

<section id="nosotros" class="section reveal">
  <h2>Nosotros</h2>
  <p>
    En Blue Rose somos un equipo de 3 desarrolladores freelance enfocados en 
    construir soluciones digitales de alto impacto. Trabajamos con tecnologías modernas
    y buenas prácticas para entregar productos rápidos, seguros y escalables.
  </p>
</section>

<section id="servicios" class="section dark reveal">
  <h2>Servicios</h2>
  <div class="cards">
    <div class="card">
      <h3>Aplicaciones Web</h3>
      <p>Desarrollo fullstack moderno con foco en performance</p>
    </div>
    <div class="card">
      <h3>Backend & APIs</h3>
      <p>Arquitecturas escalables y seguras</p>
    </div>
    <div class="card">
      <h3>Automatización</h3>
      <p>Optimización de procesos empresariales</p>
    </div>
  </div>
</section>

<section id="portfolio" class="section reveal">
  <h2>Portfolio</h2>
  <div class="cards">
    <div class="card project">Sistema de gestión</div>
    <div class="card project">E-commerce</div>
    <div class="card project">App SaaS</div>
  </div>
</section>

<section id="contacto" class="section dark reveal">
  <h2>Trabajemos juntos</h2>
  <form class="form">
    <input type="text" placeholder="Nombre" required>
    <input type="email" placeholder="Email" required>
    <textarea placeholder="Contanos tu idea"></textarea>
    <button type="submit">Enviar solicitud</button>
  </form>
</section>

<script src="/js/home.js"></script>
</body>
</html>